    "faq": {
      "title": "Frequently asked questions",
      "items": [
        { "q": "Do my clients need to pay?", "a": "No. Clients are invited free by their coach — you only pay for your own coaching plan." },
        { "q": "Is Setpal really bilingual?", "a": "Yes. The entire interface works in Arabic (RTL) and English, and exercises and forms carry both languages." },
        { "q": "Can I bring my own exercises?", "a": "Absolutely. Add custom exercises with your own videos alongside the shared global library." },
        { "q": "What happens after the trial?", "a": "You keep full access for 14 days. Pick a plan to continue — your data stays exactly where it is." }
      ]
    },
